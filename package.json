{
  "name": "durak-discord-activity",
  "version": "1.0.0",
  "private": true,
  "description": "Multiplayer Durak on Discord using Colyseus",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @durak/server",
    "dev:client": "npm run dev -w @durak/client",
    "dev": "npm run dev:server & npm run dev:client",
    "build:client": "npm run build -w @durak/client",
    "start:server": "npm run start -w @durak/server",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  }
}
