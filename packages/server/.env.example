# Server
PORT=2567
NODE_ENV=development

# MongoDB Atlas — get connection string from atlas.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/durak

# Redis (Upstash free tier) — get from upstash.com
REDIS_URL=redis://default:password@hostname:6379

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Discord App — from discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Sentry (optional) — from sentry.io
SENTRY_DSN=
