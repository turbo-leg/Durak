# ── Server ───────────────────────────────────────────────────────────────────

# MongoDB connection string (required in production)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/durak

# JWT secret for email/password auth tokens — MUST be set in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Redis connection URL (optional — enables multi-instance horizontal scaling)
REDIS_URL=redis://localhost:6379

# Port the Colyseus server listens on (default: 2567)
PORT=2567

# ── Discord OAuth (server-side token exchange) ────────────────────────────────

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ── Google sign-in (server verifies the ID token) ─────────────────────────────
# OAuth 2.0 "Web application" client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ── Apple sign-in (server verifies the identity token) ────────────────────────
# Services ID = web sign-in audience; Bundle ID = native iOS app audience.
APPLE_SERVICES_ID=com.yourcompany.durak.web
APPLE_BUNDLE_ID=com.yourcompany.durak

# ── Push Notifications (Firebase Admin) ──────────────────────────────────────
# Paste the entire service account JSON as a single-line string.
# Get it from Firebase Console → Project Settings → Service accounts → Generate key.
# Leave unset to disable push notifications.
FIREBASE_SERVICE_ACCOUNT=

# ── Client (Vite) ─────────────────────────────────────────────────────────────
# Create packages/client/.env.local and set:

# VITE_DISCORD_CLIENT_ID=your_discord_client_id   (required — app throws at startup if missing)
# VITE_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
# VITE_APPLE_SERVICES_ID=com.yourcompany.durak.web
# VITE_APPLE_REDIRECT_URI=https://your-domain.com/auth/apple/callback
